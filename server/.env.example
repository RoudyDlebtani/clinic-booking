# Postgres connection (matches docker-compose.yml).
# In production (Vercel) set this to the Neon *pooled* connection string, e.g.
# postgres://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=postgres://clinic:clinic@localhost:5433/clinic_booking

# Secret used to sign JWTs — set to a long random string in any real deployment.
JWT_SECRET=dev-secret-change-me

# Port the API listens on.
PORT=4000

# Allowed origin for CORS (the Vite dev server).
WEB_ORIGIN=http://localhost:5173
